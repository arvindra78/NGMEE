{
  "name": "ngmee-root",
  "version": "1.0.0",
  "description": "NGMEE - Next Gen Media Extraction Engine",
  "private": true,
  "workspaces": [
    "client",
    "server"
  ],
  "scripts": {
    "build": "npm install && npm run build --workspace=client",
    "start": "concurrently \"npm run start --workspace=server\" \"npm run dev --workspace=client\"",
    "serve": "cross-env NODE_ENV=production node server/server.js"
  },
  "dependencies": {
    "cross-env": "^7.0.3"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
